{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "emulators": {
    "functions": {
      "port": 5001,
      "host": "0.0.0.0"
    },
    "ui": {
      "enabled": false,
      "port": 4000,
      "host": "0.0.0.0"
    },
    "singleProjectMode": true
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "kabayansync",
          "appId": "1:1002686729184:android:7ab67da97c0e38fd5d7985",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "kabayansync",
          "appId": "1:1002686729184:ios:5ba5b21f58d239f65d7985",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "macos": {
        "default": {
          "projectId": "kabayansync",
          "appId": "1:1002686729184:ios:5ba5b21f58d239f65d7985",
          "uploadDebugSymbols": false,
          "fileOutput": "macos/Runner/GoogleService-Info.plist"
        }
      },
      "web": {
        "default": {
          "projectId": "kabayansync",
          "appId": "1:1002686729184:web:5b04796592942d245d7985",
          "fileOutput": "web/firebase-config.js"
        }
      },
      "windows": {
        "default": {
          "projectId": "kabayansync",
          "appId": "1:1002686729184:web:2fca52ffd205aac15d7985",
          "fileOutput": "windows/firebase-config.js"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "kabayansync",
          "configurations": {
            "android": "1:1002686729184:android:7ab67da97c0e38fd5d7985",
            "ios": "1:1002686729184:ios:5ba5b21f58d239f65d7985",
            "macos": "1:1002686729184:ios:5ba5b21f58d239f65d7985",
            "web": "1:1002686729184:web:5b04796592942d245d7985",
